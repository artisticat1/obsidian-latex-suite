{
	"name": "obsidian-latex-suite",
	"version": "1.11.5",
	"description": "Make typesetting LaTeX math as fast as handwriting through snippets, text expansion, and editor enhancements",
	"main": "main.js",
	"types": "src/api.d.ts",
	"exports": {
		".": {
			"types": "./src/api.d.ts"
		}
	},
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "npm run lint && npm run build && node version-bump.mjs && git add manifest.json versions.json",
		"lint": "npm run tsc && npm run eslint",
		"tsc": "tsc --noEmit -skipLibCheck",
		"eslint": "eslint --fix",
		"generator": "lezer-generator src/parser/latex.grammar -o src/parser/latex-parser.ts --typeScript"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/autocomplete": "^6.0.0",
		"@codemirror/commands": "^6.0.0",
		"@codemirror/lang-javascript": "^6.0.0",
		"@codemirror/language": "https://github.com/lishid/cm-language",
		"@codemirror/lint": "^6.0.0",
		"@codemirror/search": "^6.0.0",
		"@codemirror/state": "^6.0.0",
		"@codemirror/view": "^6.0.0",
		"@eslint/eslintrc": "^3.3.3",
		"@eslint/js": "^9.39.2",
		"@lezer/common": "^1.0.3",
		"@lezer/generator": "^1.8.0",
		"@lezer/highlight": "^1.2.3",
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "^8.55.0",
		"@typescript-eslint/parser": "^8.55.0",
		"codemirror": "^6.0.0",
		"esbuild": "^0.20.2",
		"esbuild-plugin-inline-import": "^1.0.2",
		"eslint": "^9.39.2",
		"eslint-plugin-obsidianmd": "~0.2.9",
		"globals": "^17.3.0",
		"jiti": "^2.7.0",
		"obsidian": "^1.12.3",
		"tslib": "2.3.1",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@lezer/lr": "^1.4.10",
		"@popperjs/core": "2.11.5",
		"valibot": "^1.3.1"
	}
}
